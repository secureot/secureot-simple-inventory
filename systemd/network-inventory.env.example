# /etc/default/network-inventory — configuración de network-inventory@.service
#
# Nº de hilos de captura. Para 10G, igualá al nº de colas RSS de la NIC
# (ethtool -l <iface> | grep -A4 Current).  >1 activa PACKET_FANOUT.
THREADS=4

# Estrategia de reparto del kernel entre sockets: hash | cpu | lb
FANOUT=hash

# Solo se necesita la cabecera L2; 64 reduce la copia kernel->usuario.
SNAPLEN=64

# Buffer del kernel por socket (bytes). 64 MiB; subir si hay descartes.
BUFFER_SIZE=67108864

# Base OUI (descargar de https://maclookup.app/downloads/json-database).
OUI_DB=/var/lib/network-inventory/mac-vendors-export.json

# Archivo de salida (se escribe al detener el servicio). %i = interfaz.
OUTPUT=/var/lib/network-inventory/inventario.csv
